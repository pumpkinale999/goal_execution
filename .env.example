# goal_execution 进程环境变量（GOAL_EXECUTION_* · 无 reviewer 名单）
# 本地开发默认 ~/.hermes/goal-execution/data/ge.db（dev-goal-execution.sh 自动写入）
GOAL_EXECUTION_DB_PATH=~/.hermes/goal-execution/data/ge.db

# 须与 skstudio JWT_SECRET 同值
GOAL_EXECUTION_JWT_SECRET=change-me
GOAL_EXECUTION_JWT_ALGORITHM=HS256

# skstudio BFF / internal fanout Bearer（须与 skstudio GOAL_EXECUTION_SERVICE_TOKEN 同值）
GOAL_EXECUTION_SERVICE_TOKEN=dev-ge-service-token

# WS 回调基址（commit 后 POST /internal/ge/ws-fanout）
SKSTUDIO_INTERNAL_URL=http://127.0.0.1:8000

HOST=127.0.0.1
PORT=8092

# systemd EnvironmentFile — GOAL_EXECUTION_* only (reviewer list lives in skstudio)
HERMES_SHARED_ROOT=/var/lib/hermes

GOAL_EXECUTION_DB_PATH=/var/lib/hermes/goal-execution/data/ge.db

# 须与 skstudio JWT_SECRET 同值
GOAL_EXECUTION_JWT_SECRET=替换为与-skstudio-JWT_SECRET-同值
GOAL_EXECUTION_JWT_ALGORITHM=HS256

# skstudio BFF / internal fanout Bearer（须与 skstudio GOAL_EXECUTION_SERVICE_TOKEN 同值）
GOAL_EXECUTION_SERVICE_TOKEN=替换为强随机-token-与-skstudio-同值

# WS 回调基址（commit 后 POST /internal/ge/ws-fanout）
SKSTUDIO_INTERNAL_URL=http://127.0.0.1:8000

HOST=127.0.0.1
PORT=8092
